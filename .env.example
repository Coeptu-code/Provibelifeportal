# -----------------------------
# DJANGO CORE
# -----------------------------
DJANGO_SECRET_KEY=__FROM_PASSWORD_MANAGER__
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=__RENDER_SERVICE__.onrender.com
CSRF_TRUSTED_ORIGINS=https://__RENDER_SERVICE__.onrender.com
TIME_ZONE=America/Chicago

# Security flags (production)
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

# -----------------------------
# DATABASE (SUPABASE POSTGRES)
# Use SESSION POOLER connection string
# -----------------------------
DATABASE_URL=postgresql://__USER__:__PASSWORD__@__HOST__:__PORT__/__DBNAME__?sslmode=require
SUPABASE_PROJECT_URL=https://__PROJECT_REF__.supabase.co
SUPABASE_DB_MODE=session_pooler

# -----------------------------
# SUPABASE STORAGE (PLANNED)
# -----------------------------
SUPABASE_STORAGE_ENABLED=1
SUPABASE_STORAGE_ACCESS=private
SUPABASE_ANON_KEY=__OPTIONAL_IF_NEEDED__
SUPABASE_SERVICE_ROLE_KEY=__ONLY_IF_BACKEND_STORAGE_OPS_REQUIRED__

SUPABASE_BUCKET_INVOICES=invoices
SUPABASE_BUCKET_PURCHASE_ORDERS=purchase-orders
SUPABASE_BUCKET_PACKING_SLIPS=packing-slips
SUPABASE_BUCKET_PRODUCT_DOCUMENTS=product-documents
SUPABASE_BUCKET_COA_DOCUMENTS=coa-documents

# -----------------------------
# STRIPE (HOSTED INVOICES)
# -----------------------------
STRIPE_SECRET_KEY=__FROM_STRIPE_DASHBOARD__
STRIPE_WEBHOOK_SECRET=__FROM_STRIPE_WEBHOOK_ENDPOINT__
STRIPE_CURRENCY=usd
STRIPE_INVOICING_ENABLED=1

# Webhook endpoint path (register in Stripe)
STRIPE_WEBHOOK_PATH=/webhooks/stripe/

# -----------------------------
# EMAIL (RESEND) - DEFERRED
# -----------------------------
RESEND_ENABLED=0
RESEND_API_KEY=__PENDING__
DEFAULT_FROM_EMAIL=__PENDING__
SUPPORT_EMAIL=__PENDING__

# -----------------------------
# RENDER
# -----------------------------
RENDER_EXTERNAL_HOSTNAME=__RENDER_SERVICE__.onrender.com
PYTHON_VERSION=3.13.7

# -----------------------------
# SHIPPING (OPTIONAL / OFF)
# -----------------------------
SHIPPING_PROVIDER=none
EASYPOST_ENABLED=0
EASYPOST_API_KEY=__PENDING_OPTIONAL__

# EasyPost origin defaults for future use
SHIP_FROM_NAME=__OPTIONAL_WHEN_EASYPOST_ENABLED__
SHIP_FROM_STREET1=__OPTIONAL_WHEN_EASYPOST_ENABLED__
SHIP_FROM_CITY=__OPTIONAL_WHEN_EASYPOST_ENABLED__
SHIP_FROM_STATE=__OPTIONAL_WHEN_EASYPOST_ENABLED__
SHIP_FROM_ZIP=__OPTIONAL_WHEN_EASYPOST_ENABLED__
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=__OPTIONAL_WHEN_EASYPOST_ENABLED__

# Render reference:
# Build Command: pip install -r requirements.txt && python manage.py collectstatic --noinput
# Start Command: python manage.py migrate --noinput && gunicorn supplement_portal.wsgi:application --bind 0.0.0.0:$PORT --workers 3 --timeout 120
# -----------------------------
# SHOPIFY
# -----------------------------
SHOPIFY_ENABLED=1
SHOPIFY_SHOP=__YOUR_STORE__.myshopify.com
SHOPIFY_CLIENT_ID=__FROM_SHOPIFY_PARTNER_DASHBOARD__
SHOPIFY_CLIENT_SECRET=__FROM_SHOPIFY_PARTNER_DASHBOARD__
SHOPIFY_API_VERSION=2026-04
SHOPIFY_REDIRECT_URI=https://__YOUR_DOMAIN__/webhooks/auth/shopify/callback/
SHOPIFY_ACCESS_TOKEN=__FROM_OAUTH_CALLBACK__
SHOPIFY_WEBHOOK_SECRET=__FROM_SHOPIFY_WEBHOOK_SETTINGS__
SHOPIFY_APP_SCOPES=read_draft_orders,write_draft_orders,read_orders,write_orders,read_customers,write_customers,read_products,write_shipping,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders
SHOPIFY_APP_URL=https://__YOUR_DOMAIN__
SHOPIFY_CARRIER_SERVICE_ENABLED=1
SHOPIFY_CARRIER_SERVICE_NAME=Pro Vibe Live Rates
SHOPIFY_CARRIER_CALLBACK_URL=https://__YOUR_DOMAIN__/webhooks/shopify/carrier-rate/
SHOPIFY_READ_ALL_ORDERS=0
